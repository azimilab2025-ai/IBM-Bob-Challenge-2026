# =============================================================================
# Application
# =============================================================================
APP_NAME="Supply Chain Optimization Platform"
APP_VERSION="1.0.0"
APP_ENV="development"
DEBUG=true
LOG_LEVEL="INFO"

# =============================================================================
# Server
# =============================================================================
HOST="0.0.0.0"
PORT=8000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/supply_chain_db"
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# =============================================================================
# Authentication
# =============================================================================
SECRET_KEY="change-this-to-a-long-random-secret-key-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# CORS
# =============================================================================
CORS_ORIGINS="http://localhost:3000,http://localhost:8080"

# =============================================================================
# First System Admin (seed)
# =============================================================================
FIRST_ADMIN_EMAIL="admin@example.com"
FIRST_ADMIN_PASSWORD="ChangeMe123!"
FIRST_ADMIN_FULL_NAME="System Administrator"
